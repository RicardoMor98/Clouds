# --- Database ---
# Local dev (SQLite, zero config):
DATABASE_URL="file:./dev.db"
# Production (Postgres, e.g. Supabase/Neon/Render):
# DATABASE_URL="postgresql://user:password@host:5432/clouds"

# --- Auth ---
JWT_SECRET="replace-with-a-long-random-string"
